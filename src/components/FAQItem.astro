---
export interface Props {
  q: string;
  a: string;
  open?: boolean;
}

const { q, a, open = false } = Astro.props;
---

<details
  class="group rounded-2xl border border-line bg-surface/60 open:border-accent/40 open:bg-surface/80 [&_summary::-webkit-details-marker]:hidden"
  open={open}
>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-6 p-5 sm:p-6"
  >
    <span class="font-display text-base font-semibold text-ink sm:text-lg">
      {q}
    </span>
    <span
      aria-hidden="true"
      class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-line text-muted transition-all duration-300 group-open:rotate-45 group-open:border-accent group-open:bg-accent/10 group-open:text-accent"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path
          d="M12 5v14M5 12h14"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    </span>
  </summary>
  <div class="px-5 pb-5 sm:px-6 sm:pb-6">
    <p class="text-pretty text-sm leading-relaxed text-muted sm:text-base">
      {a}
    </p>
  </div>
</details>