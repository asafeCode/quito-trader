---
import { messages } from "../i18n";
import Section from "./Section.astro";
import CTAButton from "./CTAButton.astro";

const t = messages.offer;
---

<Section id="oferta" className="bg-surface/30" ledger={true}>
  <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-5" data-reveal>
      <span class="chip">{t.chip}</span>
      <h2
        class="mt-5 text-balance font-display text-4xl font-bold leading-tight tracking-tighter text-ink sm:text-5xl lg:text-6xl"
        data-reveal-text
      >
        {t.title}
      </h2>
      <p class="mt-5 max-w-md text-pretty text-base leading-relaxed text-muted sm:text-lg">
        {t.body}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <CTAButton />
        <CTAButton to="whatsapp" variant="ghost" />
      </div>
    </div>

    <ul class="lg:col-span-7 grid gap-3 sm:grid-cols-2" data-reveal-stagger>
      {
        t.items.map((item, i) => (
          <li class="card group flex gap-4 hover:border-accent/40">
            <span class="mt-1 grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-accent/30 bg-accent/10 font-display text-xs font-bold text-accent transition-colors group-hover:bg-accent group-hover:text-bg">
              0{i + 1}
            </span>
            <div>
              <p class="font-display text-base font-semibold text-ink">
                {item.t}
              </p>
              <p class="mt-1 text-sm text-muted">{item.d}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</Section>