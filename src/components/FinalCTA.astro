---
import { messages } from "../i18n";
import Section from "./Section.astro";
import CTAButton from "./CTAButton.astro";

const t = messages.finalCta;
---

<Section
  id="cta-final"
  className="relative overflow-hidden"
  containerClass="relative"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_center,rgba(31,123,255,0.18),transparent_60%)]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-px bg-ledger-fade"
  >
  </div>

  <div
    class="grid items-center gap-10 rounded-3xl border border-accent/40 bg-gradient-to-br from-surface/90 to-surface-2/90 p-8 shadow-glow sm:p-12 lg:grid-cols-12"
    data-reveal
  >
    <div class="lg:col-span-7">
      <span class="chip-accent">{t.chip}</span>
      <h2
        class="mt-5 text-balance font-display text-4xl font-bold leading-[1.05] tracking-tighter text-ink sm:text-5xl lg:text-6xl"
        data-reveal-text
      >
        <span class="bg-gradient-to-r from-cyan via-accent to-accent-soft bg-clip-text text-transparent">
          {t.title}
        </span>
      </h2>
      <p class="mt-5 max-w-xl text-pretty text-base leading-relaxed text-muted sm:text-lg">
        {t.body}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-xs text-muted">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
          {messages.cta.microcopy}
        </span>
        <span class="hidden h-3 w-px bg-line sm:block"></span>
        <span class="inline-flex items-center gap-1.5">
          <span aria-hidden="true">🔒</span>
          {messages.badges.ssl}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span aria-hidden="true">✓</span>
          {messages.badges.regulated}
        </span>
      </div>
    </div>
    <div class="flex flex-col items-start gap-4 lg:col-span-5 lg:items-end">
      <CTAButton size="lg" magnetic />
      <CTAButton to="whatsapp" variant="ghost" />
      <p class="text-xs text-muted lg:text-right">{t.note}</p>
    </div>
  </div>
</Section>