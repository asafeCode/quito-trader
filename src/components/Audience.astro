---
import { messages } from "../i18n";
import Section from "./Section.astro";
import CTAButton from "./CTAButton.astro";

const t = messages.audience;
---

<Section id="para-quem" className="bg-surface/30" ledger={true}>
  <div class="max-w-2xl" data-reveal>
    <span class="chip">{t.chip}</span>
    <h2
      class="mt-5 text-balance font-display text-4xl font-bold leading-tight tracking-tighter text-ink sm:text-5xl lg:text-6xl"
      data-reveal-text
    >
      {t.title}
    </h2>
  </div>

  <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
    {
      t.items.map((a, i) => (
        <li class="card group relative hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_20px_60px_-15px_rgba(31,123,255,0.3)]">
          <span
            aria-hidden="true"
            class="absolute -top-px left-6 right-6 h-px bg-gradient-to-r from-transparent via-accent to-transparent"
          />
          <p class="font-display text-xs font-semibold uppercase tracking-[0.22em] text-accent">
            0{i + 1}
          </p>
          <h3 class="mt-3 font-display text-xl font-bold text-ink">
            {a.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-muted">{a.desc}</p>
        </li>
      ))
    }
  </ul>

  <div class="mt-12 flex flex-wrap items-center gap-4" data-reveal>
    <CTAButton />
    <CTAButton to="whatsapp" variant="ghost" />
  </div>
</Section>