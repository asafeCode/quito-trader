---
import { messages } from "../i18n";
import CTAButton from "./CTAButton.astro";

const t = messages.hero;
const kpis = t.kpis;
const tickers = t.ticker;
---

<section
  id="top"
  class="relative isolate overflow-hidden pt-28 pb-16 sm:pt-32 sm:pb-24 lg:pt-36 lg:pb-32"
>
  {/* Background grid + glow */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.10]"
    style="background-image: url('/matrix-bg.jpg'); background-size: cover; background-position: center; mask-image: radial-gradient(70% 60% at 70% 30%, black 30%, transparent 85%); -webkit-mask-image: radial-gradient(70% 60% at 70% 30%, black 30%, transparent 85%);"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -left-40 top-1/3 -z-10 h-96 w-96 rounded-full bg-accent/20 blur-[120px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-40 bottom-0 -z-10 h-96 w-96 rounded-full bg-cyan/10 blur-[120px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-16 -z-10 h-px bg-ledger-fade"
  >
  </div>

  <div class="container-page">
    {/* Eyebrow + Live */}
    <div class="mb-10 flex flex-wrap items-center justify-between gap-3" data-reveal>
      <span class="chip-accent">
        <span class="h-1.5 w-1.5 rounded-full bg-accent animate-blink-live"></span>
        {t.eyebrow}
      </span>
      <span class="chip">
        <span class="h-1.5 w-1.5 rounded-full bg-cyan animate-blink-live"></span>
        {t.liveBadge}
      </span>
    </div>

    {/* SPLIT 50/50 */}
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-12">
      {/* ESQUERDA: FOTO MEIO-CORPO */}
      <div class="relative order-1" data-reveal>
        {/* Tickers animados flutuando */}
        <div
          class="pointer-events-none absolute -right-2 top-4 z-10 hidden rounded-lg border border-accent/40 bg-accent/10 px-3 py-1.5 font-mono text-xs text-accent backdrop-blur-sm animate-float-y sm:block"
        >
          {tickers[0]}
        </div>
        <div
          class="pointer-events-none absolute -left-2 top-1/3 z-10 hidden rounded-lg border border-cyan/40 bg-cyan/10 px-3 py-1.5 font-mono text-xs text-cyan backdrop-blur-sm sm:block"
          style="animation-delay: -1.5s;"
        >
          {tickers[2]}
        </div>

        {/* Chart card ao fundo */}
        <div
          class="absolute -bottom-6 -right-4 z-0 hidden w-72 overflow-hidden rounded-2xl border border-line bg-surface/80 p-4 backdrop-blur-md lg:block"
          aria-hidden="true"
        >
          <div class="mb-2 flex items-center justify-between">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-muted">
                {t.chartTitle}
              </p>
              <p class="font-display text-sm font-bold text-ink">
                {t.chartPair}
              </p>
            </div>
            <span class="rounded-full border border-accent/30 bg-accent/10 px-2 py-0.5 font-mono text-[10px] text-accent">
              +0,85%
            </span>
          </div>
          {/* Mini chart SVG */}
          <svg viewBox="0 0 280 80" class="h-12 w-full" fill="none">
            <defs>
              <linearGradient id="grad" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0%" stop-color="#1F7BFF" stop-opacity="0.5" />
                <stop offset="100%" stop-color="#1F7BFF" stop-opacity="0" />
              </linearGradient>
            </defs>
            <path
              d="M0 60 L20 55 L40 62 L60 50 L80 45 L100 48 L120 38 L140 42 L160 30 L180 35 L200 22 L220 28 L240 18 L260 24 L280 12"
              stroke="#1F7BFF"
              stroke-width="2"
              stroke-linecap="round"
              fill="none"
            />
            <path
              d="M0 60 L20 55 L40 62 L60 50 L80 45 L100 48 L120 38 L140 42 L160 30 L180 35 L200 22 L220 28 L240 18 L260 24 L280 12 L280 80 L0 80 Z"
              fill="url(#grad)"
            />
          </svg>
          <p class="mt-1 font-mono text-[10px] text-muted">
            {t.chartStrategy}
          </p>
        </div>

        {/* Foto meio-corpo */}
        <div class="relative mx-auto aspect-[3/4] w-full max-w-md" data-parallax="0.08">
          <div
            aria-hidden="true"
            class="absolute -inset-6 rounded-[2.5rem] bg-gradient-to-br from-accent/30 via-cyan/15 to-transparent blur-3xl"
          >
          </div>
          <div
            class="relative h-full w-full overflow-hidden rounded-3xl border border-line/80 bg-gradient-to-b from-surface-2 to-surface shadow-glow"
          >
            <img
              src="/quito-stand.png"
              alt={messages.accessibility.altQuito}
              class="absolute inset-x-0 bottom-0 h-[110%] w-full object-cover object-bottom"
              loading="eager"
              width="800"
              height="1066"
            />
            <div
              class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-bg/80 to-transparent"
            >
            </div>
            <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between">
              <div>
                <p class="font-display text-xl font-bold text-ink">
                  {t.cardName}
                </p>
                <p class="text-[10px] uppercase tracking-[0.22em] text-muted">
                  {t.cardRole}
                </p>
              </div>
              <span
                class="rounded-full border border-accent/40 bg-accent/15 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-accent"
              >
                AO VIVO
              </span>
            </div>
          </div>
        </div>
      </div>

      {/* DIREITA: COPY + CTAs */}
      <div class="order-2">
        <h1
          class="text-balance font-display text-5xl font-bold leading-[0.95] tracking-tightest text-ink sm:text-6xl lg:text-7xl xl:text-[5.5rem]"
          data-reveal-text
        >
          {t.titleA}{" "}
          <span class="text-accent text-glow">{t.titleB}</span>
          <br />
          <span class="text-ink/95">{t.titleC}</span>
          <br />
          <span class="bg-gradient-to-r from-cyan to-accent bg-clip-text text-transparent">
            {t.titleD}
          </span>
        </h1>

        <p
          class="mt-6 max-w-xl text-pretty text-base leading-relaxed text-muted sm:text-lg"
          data-reveal
        >
          {t.subtitle}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4" data-reveal>
          <CTAButton size="lg" magnetic />
          <CTAButton to="whatsapp" variant="ghost" short />
        </div>

        <div class="mt-3 flex flex-wrap items-center gap-4 text-xs text-muted" data-reveal>
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
            {messages.cta.microcopy}
          </span>
          <span class="hidden h-3 w-px bg-line sm:block"></span>
          <span class="inline-flex items-center gap-1.5">
            <span aria-hidden="true">🔒</span>
            {messages.badges.ssl}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span aria-hidden="true">✓</span>
            {messages.badges.regulated}
          </span>
        </div>

        {/* KPIs */}
        <dl
          class="mt-10 grid max-w-xl grid-cols-3 divide-x divide-line border-y border-line"
          data-reveal-stagger
        >
          {
            kpis.map((kpi) => (
              <div class="px-4 py-4">
                <dt class="text-[10px] uppercase tracking-[0.22em] text-muted">
                  {kpi.label}
                </dt>
                <dd class="mt-1 number text-3xl font-extrabold text-ink sm:text-4xl">
                  <span
                    data-counter={kpi.value}
                    data-suffix={kpi.suffix}
                    class="text-ink"
                  >
                    {kpi.value}{kpi.suffix}
                  </span>
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>