---
import { messages } from "../i18n";

const t = messages.hero;
---

<section id="top" class="hero-shell">
  <div
    aria-hidden="true"
    class="hero-market-bg"
    style="background-image: url('/candles-bg.webp');"
  >
  </div>
  <div aria-hidden="true" class="hero-blue-wash"></div>
  <div aria-hidden="true" class="hero-vignette"></div>

  <div class="hero-grid">
    <div class="hero-col-text">
      <h1 class="hero-title">
        <span class="hero-title-1">{t.titleA}</span>
        <span class="hero-title-2">{t.titleB}</span>
        <span class="hero-title-3">{t.titleC}</span>
        <span class="hero-title-4">
          <span class="text-accent text-glow">HÁ 10 {t.titleE}</span>.
        </span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
    </div>

    <div class="hero-col-photo">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-photo-shield" aria-hidden="true"></div>
      <img
        src="/foto-quito.webp"
        alt={messages.accessibility.altQuito}
        class="hero-photo"
        loading="eager"
        width="942"
        height="1363"
      />
      <div class="hero-fade-bottom" aria-hidden="true"></div>
    </div>

    <div class="hero-col-cta">
      <h2 class="hero-motivational">
        <span class="block">
          {t.motivationalA}{" "}
          <span class="text-accent text-glow">{t.motivationalB}</span>
        </span>
        <span class="block">
          {t.motivationalC}{" "}
          <span class="text-accent text-glow">{t.motivationalD}</span>
        </span>
        <span class="block">
          {t.motivationalE}{" "}
          <span class="text-accent text-glow">{t.motivationalF}</span>
        </span>
      </h2>
      <div class="hero-rule hero-rule-right" aria-hidden="true"></div>
    </div>

    <div class="hero-cta-row">
      <a
        href={messages.links.stockity}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-stockity group"
        data-cta="stockity"
      >
        <span class="hero-cta-icon hero-cta-icon-stockity" aria-hidden="true">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18" />
            <path d="M7 14l3-3 4 4 6-6" />
            <path d="M14 9h6v6" />
          </svg>
        </span>
        <span class="min-w-0 flex-1 leading-tight">
          <span class="block whitespace-nowrap font-display text-[0.92rem] font-extrabold tracking-tight text-white min-[390px]:text-base sm:text-2xl">
            {t.primaryCta}
          </span>
          <span class="mt-1 block text-[0.62rem] uppercase tracking-[0.2em] text-white/75 min-[390px]:text-[0.68rem] sm:text-sm">
            {t.primaryCtaSub}
          </span>
        </span>
        <span aria-hidden="true" class="hero-cta-arrow">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </span>
      </a>

      <a
        href={messages.links.linktree}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-whatsapp group"
        data-cta="whatsapp"
      >
        <span class="hero-cta-icon hero-cta-icon-whatsapp" aria-hidden="true">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.52 3.48A11.86 11.86 0 0 0 12.02 0C5.4 0 .02 5.38.02 12c0 2.11.55 4.17 1.6 5.99L0 24l6.18-1.62a11.93 11.93 0 0 0 5.84 1.49h.01c6.62 0 12-5.38 12-12 0-3.2-1.25-6.21-3.51-8.48zM12.02 21.8h-.01a9.86 9.86 0 0 1-5.02-1.37l-.36-.21-3.67.96.98-3.58-.23-.37a9.86 9.86 0 0 1-1.52-5.27c0-5.46 4.44-9.9 9.91-9.9 2.65 0 5.13 1.03 7 2.9a9.84 9.84 0 0 1 2.9 7c0 5.46-4.45 9.9-9.91 9.9zm5.45-7.42c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15s-.77.97-.95 1.17c-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37s-1.04 1.01-1.04 2.47 1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.34z" />
          </svg>
        </span>
        <span class="min-w-0 flex-1 leading-tight">
          <span class="block whitespace-nowrap font-display text-[0.86rem] font-extrabold tracking-tight text-white min-[390px]:text-[0.9rem] sm:text-xl">
            {t.secondaryCta}
          </span>
          <span class="mt-1 block whitespace-nowrap text-[0.58rem] uppercase tracking-[0.12em] text-white/60 min-[390px]:text-[0.64rem] sm:text-sm">
            {t.secondaryCtaSub}
          </span>
        </span>
        <span aria-hidden="true" class="hero-cta-arrow">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </span>
      </a>
    </div>

    <div class="hero-below-cue">
      <a href="#hero-context" class="hero-scroll-arrow" aria-label="Rolar para ver mais">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

<section id="hero-context" class="hero-context-mini" aria-label="Ambiente Quito Trader">
  <div class="hero-context-inner">
    <div class="hero-context-line" aria-hidden="true"></div>
    <p>{t.motivationalSub}</p>
  </div>
</section>
