---
import { messages } from "../i18n";
import CTAButton from "./CTAButton.astro";

const t = messages.hero;
---

<section
  id="top"
  class="relative isolate overflow-hidden snap-start min-h-[calc(100svh-6rem)] flex flex-col justify-center"
>
  {/* Market texture de fundo */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.12]"
    style="background-image: url('/candles-bg.webp'); background-size: cover; background-position: center;"
  >
  </div>

  {/* Glow ambiente */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -left-40 top-1/4 -z-10 h-[420px] w-[420px] rounded-full bg-accent/20 blur-[130px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-40 bottom-0 -z-10 h-80 w-80 rounded-full bg-cyan/10 blur-[120px]"
  >
  </div>

  <div class="container-page flex flex-col items-stretch gap-6 py-6 sm:py-8 lg:flex-row lg:items-center lg:gap-6 xl:gap-8 lg:py-0">
    {/* ESQUERDA — texto consolidado */}
    <div class="order-2 w-full text-center lg:order-1 lg:w-2/5 lg:text-left" data-reveal>
      <div data-reveal-text>
        <p class="font-display text-[2rem] font-bold leading-[1.02] tracking-tighter text-white sm:text-3xl lg:text-3xl xl:text-4xl 2xl:text-5xl">
          Opere na <span class="text-accent text-glow">Stockity</span>
        </p>
        <p class="mt-3 font-medium text-white/90 sm:text-xl lg:text-2xl xl:text-3xl">
          com o método que eu uso há mais de 10 anos.
        </p>
        <p class="mt-4 text-pretty text-sm leading-relaxed text-white/70 sm:text-base lg:text-sm xl:text-base">
          {t.subtitle}
        </p>
      </div>
    </div>

    {/* CENTRO — foto com padding bottom + gradiente fade-out */}
    <div class="relative order-1 flex w-full justify-center lg:order-2 lg:flex-1" data-reveal>
      {/* Glow atrás da foto */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 -z-10 rounded-full bg-gradient-to-br from-accent/25 via-cyan/10 to-transparent blur-3xl"
      >
      </div>
      <div class="relative">
        <img
          src="/foto-quito.webp"
          alt={messages.accessibility.altQuito}
          class="relative z-10 mx-auto block h-full w-full max-w-[280px] object-contain pb-6 sm:max-w-[320px] sm:pb-8 lg:max-w-[420px] lg:pb-10 xl:max-w-[480px] xl:pb-12"
          loading="eager"
          width="1122"
          height="1402"
        />
        {/* Gradiente fade-out na base — esconde o corte do corpo */}
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-x-0 bottom-0 z-0 h-24 bg-gradient-to-b from-transparent to-bg sm:h-28 lg:h-32"
        >
        </div>
      </div>
    </div>

    {/* DIREITA — CTAs */}
    <div
      class="order-3 flex w-full flex-col items-stretch justify-center gap-3 lg:w-1/4 lg:items-start lg:gap-4"
      data-reveal
    >
      <CTAButton size="lg" magnetic />
      <CTAButton to="whatsapp" variant="ghost" short />
    </div>
  </div>

  {/* Seta animada — scroll cue */}
  <div
    class="pointer-events-none absolute inset-x-0 bottom-4 flex justify-center sm:bottom-6"
    aria-hidden="true"
    data-scroll-cue
  >
    <div class="animate-scroll-cue text-white/50">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 5v14M19 12l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>