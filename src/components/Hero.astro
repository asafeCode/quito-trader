---
import { messages } from "../i18n";
import CTAButton from "./CTAButton.astro";

const t = messages.hero;
const kpis = t.kpis;
const tickers = t.ticker;
---

<section
  id="top"
  class="relative isolate overflow-hidden pt-28 pb-16 sm:pt-32 sm:pb-24 lg:pt-32 lg:pb-32"
>
  {/* Background grid + glow */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.12]"
    style="background-image: url('/candles-bg.webp'); background-size: cover; background-position: center; mask-image: radial-gradient(70% 60% at 30% 50%, black 30%, transparent 85%); -webkit-mask-image: radial-gradient(70% 60% at 30% 50%, black 30%, transparent 85%);"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -left-40 top-1/3 -z-10 h-[500px] w-[500px] rounded-full bg-accent/25 blur-[140px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-40 bottom-0 -z-10 h-96 w-96 rounded-full bg-cyan/10 blur-[120px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-16 -z-10 h-px bg-ledger-fade"
  >
  </div>

  <div class="container-page">
    {/* Eyebrow + Live */}
    <div class="mb-12 flex flex-wrap items-center justify-between gap-3" data-reveal>
      <span class="chip-accent">
        <span class="h-1.5 w-1.5 rounded-full bg-accent animate-blink-live"></span>
        {t.eyebrow}
      </span>
      <span class="chip">
        <span class="h-1.5 w-1.5 rounded-full bg-cyan animate-blink-live"></span>
        {t.liveBadge}
      </span>
    </div>

    {/* SPLIT 50/50 */}
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      {/* ESQUERDA: COPY + CTAs */}
      <div class="order-2 lg:order-1">
        <h1
          class="text-balance font-display text-3xl font-bold leading-[1.05] tracking-tighter text-ink sm:text-4xl lg:text-5xl xl:text-6xl"
          data-reveal-text
        >
          <span class="block font-medium text-ink/90">{t.titleA}</span>
          <span class="block text-accent text-glow font-bold">{t.titleB}</span>
          <span class="block font-medium text-ink/90">{t.titleC}</span>
          <span class="block bg-gradient-to-r from-cyan via-accent to-accent-soft bg-clip-text text-transparent font-bold">
            {t.titleD}
          </span>
        </h1>

        <p
          class="mt-8 max-w-xl text-pretty text-base leading-relaxed text-muted sm:text-lg"
          data-reveal
        >
          {t.subtitle}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-4" data-reveal>
          <CTAButton size="lg" magnetic />
          <CTAButton to="whatsapp" variant="ghost" short />
        </div>

        <div class="mt-4 flex flex-wrap items-center gap-4 text-xs text-muted" data-reveal>
          <span class="inline-flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
            {messages.cta.microcopy}
          </span>
          <span class="hidden h-3 w-px bg-line sm:block"></span>
          <span class="inline-flex items-center gap-1.5">
            <span aria-hidden="true">🔒</span>
            {messages.badges.ssl}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span aria-hidden="true">✓</span>
            {messages.badges.regulated}
          </span>
        </div>

        {/* KPIs */}
        <dl
          class="mt-12 grid max-w-xl grid-cols-3 divide-x divide-line border-y border-line"
          data-reveal-stagger
        >
          {
            kpis.map((kpi) => (
              <div class="px-4 py-4">
                <dt class="text-[10px] uppercase tracking-[0.22em] text-muted">
                  {kpi.label}
                </dt>
                <dd class="mt-1 number text-3xl font-extrabold text-ink sm:text-4xl">
                  <span
                    data-counter={kpi.value}
                    data-suffix={kpi.suffix}
                    class="text-ink"
                  >
                    {kpi.value}{kpi.suffix}
                  </span>
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      {/* DIREITA: FOTO NÍTIDA */}
      <div class="relative order-1 lg:order-2" data-reveal>
        {/* Glow grande atrás da foto */}
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -inset-10 -z-10 rounded-[3rem] bg-gradient-to-br from-accent/40 via-cyan/15 to-transparent blur-3xl"
        >
        </div>

        {/* Ticker 1 — WIN (top-right da foto) */}
        <div
          class="pointer-events-none absolute -right-3 top-12 z-20 hidden rounded-lg border border-accent/40 bg-accent/10 px-3 py-1.5 font-mono text-xs text-accent backdrop-blur-md animate-float-y sm:block"
        >
          {tickers[0]}
        </div>

        {/* Ticker 2 — BTC (bottom-left da foto) */}
        <div
          class="pointer-events-none absolute -left-3 bottom-20 z-20 hidden rounded-lg border border-cyan/40 bg-cyan/10 px-3 py-1.5 font-mono text-xs text-cyan backdrop-blur-md sm:block"
          style="animation-delay: -1.5s;"
        >
          {tickers[2]}
        </div>

        {/* Foto pura — alta resolução */}
        <div
          class="relative mx-auto aspect-[3/4] w-full max-w-md"
          data-parallax="0.06"
        >
          <img
            src="/quito-stockity.webp"
            alt={messages.accessibility.altQuito}
            class="relative z-10 h-full w-full object-contain object-bottom"
            loading="eager"
            width="1122"
            height="1402"
          />
        </div>
      </div>
    </div>
  </div>
</section>
