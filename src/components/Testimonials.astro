---
import { messages } from "../i18n";
import Section from "./Section.astro";

const t = messages.testimonials;
---

<Section id="resultados" className="relative">
  <div class="max-w-2xl" data-reveal>
    <span class="chip">{t.chip}</span>
    <h2
      class="mt-5 text-balance font-display text-4xl font-bold leading-tight tracking-tighter text-ink sm:text-5xl lg:text-6xl"
      data-reveal-text
    >
      {t.titleA} <span class="text-accent text-glow">{t.titleB}</span>{t.titleEnd}
    </h2>
    <p class="mt-4 text-pretty text-sm text-muted sm:text-base">{t.note}</p>
  </div>

  {/* Counter banner */}
  <div
    class="mt-10 grid grid-cols-1 gap-6 rounded-2xl border border-line bg-gradient-to-r from-surface to-surface-2 p-6 sm:grid-cols-3 sm:p-8"
    data-reveal
  >
    <div class="sm:col-span-2 flex flex-col justify-center">
      <p class="font-display text-6xl font-extrabold text-ink sm:text-7xl">
        <span data-counter={t.counterValue} data-suffix={t.counterSuffix}>
          {t.counterValue}{t.counterSuffix}
        </span>
      </p>
      <p class="mt-2 text-sm uppercase tracking-[0.22em] text-muted">
        {t.counterLabel}
      </p>
    </div>
    <div class="grid grid-cols-3 gap-4 border-l border-line pl-6 sm:flex sm:flex-col sm:gap-2">
      <div>
        <p class="font-display text-2xl font-bold text-ink">+10</p>
        <p class="text-[10px] uppercase tracking-[0.22em] text-muted">anos de mercado</p>
      </div>
      <div>
        <p class="font-display text-2xl font-bold text-ink">5</p>
        <p class="text-[10px] uppercase tracking-[0.22em] text-muted">mercados</p>
      </div>
      <div>
        <p class="font-display text-2xl font-bold text-accent">M1</p>
        <p class="text-[10px] uppercase tracking-[0.22em] text-muted">price action raiz</p>
      </div>
    </div>
  </div>

  <div class="mt-10 grid gap-6 lg:grid-cols-2" data-reveal-stagger>
    {
      t.items.map((item) => (
        <figure class="card-elevated relative overflow-hidden p-5">
          <span
            aria-hidden="true"
            class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-accent/15 blur-2xl"
          />
          <img
            src={item.image}
            alt={`Conversa real com ${item.name}`}
            class="w-full rounded-xl border border-line"
            loading="lazy"
            width="640"
            height="800"
          />
          <figcaption class="mt-5 flex items-center justify-between">
            <div>
              <p class="font-display text-base font-semibold text-ink">
                {item.name}
              </p>
              <p class="text-[10px] uppercase tracking-[0.22em] text-muted">
                {item.role}
              </p>
            </div>
            <span
              aria-hidden="true"
              class="font-display text-3xl font-extrabold text-accent/40"
            >
              “
            </span>
          </figcaption>
          <blockquote class="mt-3 text-sm leading-relaxed text-ink/90 sm:text-base">
            {item.quote}
          </blockquote>
        </figure>
      ))
    }
  </div>
</Section>