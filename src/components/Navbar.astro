---
import { messages } from "../i18n";
import CTAButton from "./CTAButton.astro";

const t = messages.nav;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-accent/25 bg-bg-deep/92 shadow-[0_22px_70px_-34px_rgba(31,123,255,0.85)] backdrop-blur-xl"
>
  <nav
    class="container-page flex h-24 items-center justify-between gap-3 sm:h-28 sm:gap-5"
    aria-label={t.accessibilityNav}
  >
    <a
      href="#top"
      class="group flex min-w-0 items-center gap-3 sm:gap-4"
      aria-label={`${messages.site.name} - ${t.accessibilityHome}`}
    >
      <span class="grid h-14 w-14 shrink-0 place-items-center rounded-full border border-accent/30 bg-bg/80 shadow-[0_0_0_1px_rgba(31,123,255,0.08),0_0_44px_-18px_rgba(31,123,255,0.95)] transition-colors group-hover:border-accent/60 sm:h-16 sm:w-16">
        <img
          src="/logo.webp"
          alt={messages.site.name}
          width="64"
          height="64"
          class="h-11 w-11 object-contain sm:h-12 sm:w-12"
          loading="eager"
        />
      </span>
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="font-display text-sm font-extrabold tracking-tighter text-ink transition-colors group-hover:text-accent-soft sm:text-xl">
          QUITOTRADER
        </span>
        <span class="mt-1 whitespace-nowrap text-[8px] uppercase tracking-[0.22em] text-ink/70 sm:text-xs sm:tracking-[0.32em]">
          {messages.site.tagline}
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-1 rounded-full border border-line/70 bg-surface/40 p-1 backdrop-blur-md md:flex">
      <li>
        <a
          href="#sobre"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.sobre}
        </a>
      </li>
      <li>
        <a
          href="#metodo"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.metodo}
        </a>
      </li>
      <li>
        <a
          href="#resultados"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.resultados}
        </a>
      </li>
    </ul>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a
        href={messages.links.stockity}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-12 items-center justify-center rounded-full border border-line/80 bg-bg/50 px-4 text-sm font-extrabold text-ink shadow-[inset_0_0_0_1px_rgba(31,123,255,0.04),0_18px_48px_-30px_rgba(31,123,255,0.9)] transition-colors hover:border-accent/55 hover:bg-accent/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg sm:h-14 sm:px-5 sm:text-base"
        aria-label={messages.accessibility.altStockity}
      >
        <img
          src="/stockity.png"
          alt={messages.accessibility.altStockity}
          class="h-5 w-auto object-contain sm:h-6"
          loading="lazy"
          width="24"
          height="24"
        />
      </a>

      <span class="hidden lg:inline-flex">
        <CTAButton short />
      </span>

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-accent/40 bg-accent text-white shadow-[0_18px_44px_-16px_rgba(31,123,255,0.9)] transition-transform hover:scale-105 md:hidden sm:h-14 sm:w-14 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 7h14M5 12h14M5 17h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-accent/15 bg-bg-deep/96 shadow-[0_24px_70px_-36px_rgba(31,123,255,0.7)] backdrop-blur-xl md:hidden"
  >
    <nav class="container-page flex flex-col gap-1 py-4" aria-label="Menu mobile">
      <a
        href="#sobre"
        class="rounded-xl px-3 py-3 text-sm font-semibold text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.sobre}
      </a>
      <a
        href="#metodo"
        class="rounded-xl px-3 py-3 text-sm font-semibold text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.metodo}
      </a>
      <a
        href="#resultados"
        class="rounded-xl px-3 py-3 text-sm font-semibold text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.resultados}
      </a>
      <a
        href="#faq"
        class="rounded-xl px-3 py-3 text-sm font-semibold text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {messages.faq.title}
      </a>
    </nav>
  </div>
</header>
