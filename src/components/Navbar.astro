---
import { messages } from "../i18n";
import CTAButton from "./CTAButton.astro";

const t = messages.nav;
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-accent/15 bg-bg/72 shadow-[0_18px_60px_-36px_rgba(31,123,255,0.65)] backdrop-blur-xl"
>
  <nav
    class="container-page flex h-24 items-center justify-between gap-3 sm:gap-6"
    aria-label={t.accessibilityNav}
  >
    <a
      href="#top"
      class="group flex min-w-0 items-center gap-3"
      aria-label={`${messages.site.name} - ${t.accessibilityHome}`}
    >
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full border border-accent/25 bg-surface/80 shadow-[0_0_34px_-16px_rgba(31,123,255,0.9)] transition-colors group-hover:border-accent/55">
        <img
          src="/logo.webp"
          alt={messages.site.name}
          width="48"
          height="48"
          class="h-10 w-10 object-contain"
          loading="eager"
        />
      </span>
      <span class="hidden flex-col leading-tight sm:flex">
        <span class="font-display text-base font-bold tracking-tighter text-ink transition-colors group-hover:text-accent-soft">
          QUITOTRADER
        </span>
        <span class="max-w-[168px] truncate text-[10px] uppercase tracking-[0.22em] text-muted">
          {messages.site.tagline}
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-1 rounded-full border border-line/70 bg-surface/45 p-1 backdrop-blur-md md:flex">
      <li>
        <a
          href="#sobre"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.sobre}
        </a>
      </li>
      <li>
        <a
          href="#metodo"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.metodo}
        </a>
      </li>
      <li>
        <a
          href="#resultados"
          class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t.resultados}
        </a>
      </li>
    </ul>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a
        href={messages.links.stockity}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-full border border-line/80 bg-surface/70 px-3 py-1.5 text-xs text-muted transition-colors hover:border-accent/60 hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg lg:flex"
        aria-label={messages.accessibility.altStockity}
      >
        <img
          src="/stockity.png"
          alt={messages.accessibility.altStockity}
          class="h-5 w-auto object-contain"
          loading="lazy"
          width="60"
        />
        <span class="font-medium">{t.parceria}</span>
      </a>
      <CTAButton short />

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-line bg-surface/70 text-ink shadow-[0_10px_30px_-18px_rgba(31,123,255,0.8)] md:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-accent/15 bg-bg/95 shadow-[0_24px_70px_-36px_rgba(31,123,255,0.7)] backdrop-blur-xl md:hidden"
  >
    <nav class="container-page flex flex-col gap-1 py-4" aria-label="Menu mobile">
      <a
        href="#sobre"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.sobre}
      </a>
      <a
        href="#metodo"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.metodo}
      </a>
      <a
        href="#resultados"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {t.resultados}
      </a>
      <a
        href="#faq"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-muted transition-colors hover:bg-accent/10 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
      >
        {messages.faq.title}
      </a>
    </nav>
  </div>
</header>
