---
import { messages } from "../i18n";
---

<div
  class="fixed inset-x-0 bottom-0 z-40 border-t border-accent/30 bg-bg/95 px-4 pb-[max(0.75rem,env(safe-area-inset-bottom))] pt-3 lg:hidden"
>
  <a
    href={messages.links.stockity}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-primary-lg flex w-full animate-pulse-glow"
  >
    <span>{messages.stickyCta.label}</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M5 12h14M13 6l6 6-6 6"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </a>
</div>