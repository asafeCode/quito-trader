---
// Componente de audio de fundo com autoplay mudo + botao de toggle + modal prompt
---

<audio
  id="bg-audio"
  src="/quito-trader.mp3"
  loop
  preload="metadata"
  autoplay
  muted
  class="hidden"
>
  <track kind="captions" />
</audio>

<button
  id="audio-toggle"
  type="button"
  aria-label="Ativar som de fundo"
  aria-pressed="false"
  class="fixed bottom-5 left-5 z-50 grid h-12 w-12 place-items-center rounded-full border border-accent/40 bg-[rgba(5,8,16,0.72)] text-white shadow-[0_0_34px_-18px_rgba(31,123,255,0.95)] backdrop-blur-md transition-all hover:border-accent/65 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
  <svg
    id="icon-muted"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M11 5L6 9H2v6h4l5 4V5z"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
    />
    <line
      x1="20.5"
      y1="4"
      x2="3.5"
      y2="20"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
    />
  </svg>
  <svg
    id="icon-playing"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
    class="hidden"
  >
    <path
      d="M11 5L6 9H2v6h4l5 4V5z"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
    />
    <path
      d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    />
  </svg>
</button>

{/* Badge sutil — indica que o som está mudo, some quando ativado */}
<script>
  const audio = document.getElementById("bg-audio") as HTMLAudioElement | null;
  const btn = document.getElementById("audio-toggle") as HTMLButtonElement | null;
  const iconMuted = document.getElementById("icon-muted");
  const iconPlaying = document.getElementById("icon-playing");

  if (audio && btn && iconMuted && iconPlaying) {
    audio.volume = 0.10;
    audio.muted = true;

    const showPlaying = () => {
      iconMuted.classList.add("hidden");
      iconPlaying.classList.remove("hidden");
      btn.setAttribute("aria-label", "Silenciar som de fundo");
      btn.setAttribute("aria-pressed", "true");
    };
    const showMuted = () => {
      iconMuted.classList.remove("hidden");
      iconPlaying.classList.add("hidden");
      btn.setAttribute("aria-label", "Ativar som de fundo");
      btn.setAttribute("aria-pressed", "false");
    };
    showMuted();
    audio.play().catch(() => {});

    btn.addEventListener("click", () => {
      if (audio.muted) {
        audio.muted = false;
        audio.play().catch(() => {});
        showPlaying();
      } else {
        audio.muted = true;
        showMuted();
      }
    });
  }
</script>
