---
// Componente de audio de fundo com autoplay mudo + botao de toggle + modal prompt
---

<audio
  id="bg-audio"
  src="/quito-trader.mp3"
  loop
  preload="metadata"
  autoplay
  muted
  class="hidden"
>
  <track kind="captions" />
</audio>

<button
  id="audio-toggle"
  type="button"
  aria-label="Ativar som de fundo"
  aria-pressed="false"
  class="fixed bottom-5 left-5 z-30 flex h-12 w-12 items-center justify-center rounded-full border border-accent/30 bg-bg/85 text-ink shadow-glow backdrop-blur-md transition-all hover:scale-105 hover:border-accent/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
  <svg
    id="icon-muted"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M11 5L6 9H2v6h4l5 4V5z"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
    />
    <line
      x1="22"
      y1="9"
      x2="16"
      y2="15"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    />
    <line
      x1="16"
      y1="9"
      x2="22"
      y2="15"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    />
  </svg>
  <svg
    id="icon-playing"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
    class="hidden"
  >
    <path
      d="M11 5L6 9H2v6h4l5 4V5z"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
    />
    <path
      d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
    />
  </svg>
</button>

{/* Badge sutil — indica que o som está mudo, some quando ativado */}
<span
  id="audio-hint"
  class="pointer-events-none absolute bottom-5 left-20 z-30 hidden -translate-y-1/2 items-center gap-1.5 rounded-full bg-bg/80 px-2.5 py-1 text-[10px] font-medium uppercase tracking-[0.15em] text-muted backdrop-blur-md sm:flex"
  aria-hidden="true"
>
  <span class="relative flex h-1.5 w-1.5">
    <span class="absolute inset-0 animate-ping rounded-full bg-accent/60"></span>
    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
  </span>
  Clique para o som
</span>

<script>
  const audio = document.getElementById("bg-audio") as HTMLAudioElement | null;
  const btn = document.getElementById("audio-toggle") as HTMLButtonElement | null;
  const iconMuted = document.getElementById("icon-muted");
  const iconPlaying = document.getElementById("icon-playing");
  const hintEl = document.getElementById("audio-hint") as HTMLSpanElement | null;

  if (audio && btn && iconMuted && iconPlaying) {
    audio.volume = 0.10;
    audio.muted = false;

    const showPlaying = () => {
      iconMuted.classList.add("hidden");
      iconPlaying.classList.remove("hidden");
      btn.setAttribute("aria-label", "Silenciar som de fundo");
      btn.setAttribute("aria-pressed", "true");
      if (hintEl) hintEl.classList.add("hidden");
    };
    const showMuted = () => {
      iconMuted.classList.remove("hidden");
      iconPlaying.classList.add("hidden");
      btn.setAttribute("aria-label", "Ativar som de fundo");
      btn.setAttribute("aria-pressed", "false");
    };
    const showHint = () => {
      if (hintEl && audio.muted) hintEl.classList.remove("hidden");
    };

    audio.play().then(showPlaying).catch(() => {
      audio.muted = true;
      showMuted();
      showHint();
    });

    const tryUnmute = () => {
      if (audio.muted) {
        audio.muted = false;
        audio.play()
          .then(showPlaying)
          .catch(() => {});
      }
      document.removeEventListener("click", tryUnmute);
      document.removeEventListener("scroll", tryUnmute);
      document.removeEventListener("keydown", tryUnmute);
      document.removeEventListener("touchstart", tryUnmute);
    };
    document.addEventListener("click", tryUnmute);
    document.addEventListener("scroll", tryUnmute);
    document.addEventListener("keydown", tryUnmute);
    document.addEventListener("touchstart", tryUnmute);

    btn.addEventListener("click", () => {
      if (audio.muted) {
        audio.muted = false;
        audio.play().catch(() => {});
        showPlaying();
      } else {
        audio.muted = true;
        showMuted();
        showHint();
      }
    });
  }
</script>