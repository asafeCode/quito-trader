---
import "../styles/global.css";
import { messages } from "../i18n";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Quito Trader — Opere na Stockity com o método Price Action Raiz",
  description = "Mentoria em Price Action Raiz com Quito Trader. +10 anos operando Mini Índice, Mini Dólar, Forex e Cripto na Stockity.",
} = Astro.props;

const canonicalUrl = "https://quitotrader.com.br";

const faqLd = messages.faq.items.map((f) => ({
  "@type": "Question",
  name: f.q,
  acceptedAnswer: { "@type": "Answer", text: f.a },
}));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Quito Trader",
    jobTitle: "Trader e Mentor",
    description: description,
    knowsAbout: ["Price Action", "Mini Índice", "Mini Dólar", "Forex", "Cripto"],
    sameAs: [messages.links.linktree],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Mentoria Price Action Raiz",
    provider: { "@type": "Person", name: "Quito Trader" },
    areaServed: { "@type": "Country", name: "Brasil" },
    description: messages.offer.body,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqLd,
  },
  {
    "@context": "https://schema.org",
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "200",
    itemReviewed: {
      "@type": "Service",
      name: "Mentoria Price Action Raiz",
    },
  },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050810" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Quito Trader" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- Google Analytics 4 -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-W84LLJ626N"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-W84LLJ626N");
    </script>
  </head>
  <body class="overflow-x-hidden">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[200] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:shadow-glow"
    >
      Pular para conteúdo
    </a>
    <slot />
  </body>
</html>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";

  gsap.registerPlugin(ScrollTrigger);

  /* ----- Lenis smooth scroll ----- */
  const lenis = new Lenis({
    duration: 1.1,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    smoothWheel: true,
  });

  lenis.on("scroll", ScrollTrigger.update);

  gsap.ticker.add((time: number) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  /* ----- Reveal on scroll (global) ----- */
  const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
  reveals.forEach((el) => {
    gsap.fromTo(
      el,
      { y: 32, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.9,
        ease: "power3.out",
        scrollTrigger: {
          trigger: el,
          start: "top 88%",
        },
      }
    );
  });

  const revealTexts = document.querySelectorAll<HTMLElement>("[data-reveal-text]");
  revealTexts.forEach((el) => {
    const html = el.innerHTML;
    const text = el.textContent ?? "";
    el.innerHTML = text
      .split(/(\s+)/)
      .map((part) => {
        if (part.trim() === "") return part;
        return `<span class="inline-block overflow-hidden align-bottom"><span class="word inline-block">${part}</span></span>`;
      })
      .join("");
    const words = el.querySelectorAll<HTMLElement>(".word");
    gsap.fromTo(
      words,
      { yPercent: 110, opacity: 0 },
      {
        yPercent: 0,
        opacity: 1,
        duration: 0.7,
        ease: "power3.out",
        stagger: 0.04,
        scrollTrigger: {
          trigger: el,
          start: "top 85%",
        },
        onStart: () => {
          el.innerHTML = html;
        },
      }
    );
  });

  const staggers = document.querySelectorAll<HTMLElement>("[data-reveal-stagger]");
  staggers.forEach((parent) => {
    const children = parent.querySelectorAll<HTMLElement>(":scope > *");
    gsap.fromTo(
      children,
      { y: 28, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.7,
        ease: "power3.out",
        stagger: 0.1,
        scrollTrigger: {
          trigger: parent,
          start: "top 85%",
        },
      }
    );
  });

  /* ----- Counters ----- */
  const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
  counters.forEach((el) => {
    const target = parseFloat(el.getAttribute("data-counter") ?? "0");
    const suffix = el.getAttribute("data-suffix") ?? "";
    const obj = { v: 0 };
    gsap.to(obj, {
      v: target,
      duration: 2,
      ease: "power2.out",
      scrollTrigger: {
        trigger: el,
        start: "top 90%",
      },
      onUpdate: () => {
        const isInt = Number.isInteger(target);
        el.textContent =
          (isInt ? Math.round(obj.v).toString() : obj.v.toFixed(1)) + suffix;
      },
    });
  });

  /* ----- Parallax (data-parallax="0.2") ----- */
  const parallaxes = document.querySelectorAll<HTMLElement>("[data-parallax]");
  parallaxes.forEach((el) => {
    const strength = parseFloat(el.getAttribute("data-parallax") ?? "0.15");
    gsap.fromTo(
      el,
      { yPercent: -strength * 30 },
      {
        yPercent: strength * 30,
        ease: "none",
        immediateRender: false,
        scrollTrigger: {
          trigger: el,
          start: "top bottom",
          end: "bottom top",
          scrub: 0.5,
        },
      }
    );
  });

  /* ----- Magnetic buttons ----- */
  const magneticEls = document.querySelectorAll<HTMLElement>("[data-magnetic]");
  magneticEls.forEach((el) => {
    const strength = 0.35;
    const onMove = (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(el, { x: x * strength, y: y * strength, duration: 0.5, ease: "power3.out" });
    };
    const onLeave = () => gsap.to(el, { x: 0, y: 0, duration: 0.7, ease: "elastic.out(1, 0.4)" });
    el.addEventListener("mousemove", onMove);
    el.addEventListener("mouseleave", onLeave);
  });

  /* ----- Custom cursor ----- */
  const cursor = document.getElementById("cursor-dot");
  const ring = document.getElementById("cursor-ring");
  if (cursor && ring && window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    document.documentElement.classList.add("has-cursor");
    const xTo = gsap.quickTo(cursor, "x", { duration: 0.2, ease: "power3.out" });
    const yTo = gsap.quickTo(cursor, "y", { duration: 0.2, ease: "power3.out" });
    const xToR = gsap.quickTo(ring, "x", { duration: 0.5, ease: "power3.out" });
    const yToR = gsap.quickTo(ring, "y", { duration: 0.5, ease: "power3.out" });

    window.addEventListener("mousemove", (e) => {
      xTo(e.clientX);
      yTo(e.clientY);
      xToR(e.clientX);
      yToR(e.clientY);
    });

    document.addEventListener("mouseover", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("a, button, [data-cursor-hover]")) {
        gsap.to([cursor, ring], { scale: 2.2, opacity: 0.6, duration: 0.3 });
      }
    });
    document.addEventListener("mouseout", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("a, button, [data-cursor-hover]")) {
        gsap.to([cursor, ring], { scale: 1, opacity: 1, duration: 0.3 });
      }
    });
  }

  /* ----- Refresh ScrollTrigger on load ----- */
  window.addEventListener("load", () => {
    ScrollTrigger.refresh();
  });

  /* ----- GA4 tracking helpers ----- */
  function track(event: string, params: Record<string, unknown> = {}) {
    if (typeof (window as any).gtag === "function") {
      (window as any).gtag("event", event, params);
    }
  }

  /* ----- Click tracking (delegated) ----- */
  document.addEventListener("click", (e: MouseEvent) => {
    const link = (e.target as HTMLElement).closest("a[href]");
    if (!link) return;
    const href = link.getAttribute("href") || "";
    const label = (link.textContent || "").trim() || link.getAttribute("aria-label") || "";
    if (href.includes("stockity.com")) {
      track("click_cta", { cta: "stockity", label });
    } else if (href.includes("linktr.ee") || href.includes("wa.me") || href.includes("whatsapp")) {
      track("click_cta", { cta: "whatsapp", label });
    } else if (href.startsWith("#")) {
      track("click_nav", { target: href });
    }
  });

  /* ----- Scroll depth tracking ----- */
  let lastDepth = 0;
  const milestones = [25, 50, 75, 100];
  let scrollTimer: number | undefined;
  function onScrollDepth() {
    if (scrollTimer) return;
    scrollTimer = window.setTimeout(() => {
      scrollTimer = undefined;
      const max = document.body.scrollHeight - window.innerHeight;
      if (max <= 0) return;
      const depth = Math.round((window.scrollY / max) * 100);
      const hit = milestones.find((m) => depth >= m && lastDepth < m);
      if (hit) {
        track("scroll_depth", { depth: hit });
        lastDepth = depth;
      }
    }, 250);
  }
  window.addEventListener("scroll", onScrollDepth, { passive: true });

  /* ----- Mobile menu toggle ----- */
  const menuBtn = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", String(!isOpen));
      mobileMenu.classList.toggle("hidden");
    });
  }

  /* ----- Hero scroll cue (esconder ao rolar) ----- */
  const scrollCue = document.querySelector<HTMLElement>("[data-scroll-cue]");
  if (scrollCue) {
    gsap.to(scrollCue, {
      opacity: 0,
      scrollTrigger: {
        trigger: "section#top",
        start: "top top-=15%",
        end: "top top-=45%",
        scrub: true,
      },
    });
  }
</script>